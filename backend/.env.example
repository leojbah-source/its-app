# ============================================================
# KCA Indian Talent Scan (ITS) - Backend Environment Variables
# Copy this file to .env and fill in real values. Never commit .env
# ============================================================

# --- Server ---
PORT=4000
NODE_ENV=development
FRONTEND_URL=https://talentscan.kcabah.com

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=kca_its_user
DB_PASSWORD=changeme
DB_NAME=kca_its
DB_SSL=false

# --- JWT Auth ---
JWT_SECRET=changeme_long_random_secret
JWT_EXPIRES_IN=12h

# --- KCA Membership verification (live API) ---
MEMBERSHIP_API_BASE_URL=https://mem.kcabah.com/api
MEMBERSHIP_API_KEY=changeme

# --- WhatsApp (pluggable provider) ---
# WHATSAPP_PROVIDER = green-api | whatsapp-business
WHATSAPP_PROVIDER=green-api
WHATSAPP_API_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE_ID=

# --- OTP (manual send, judge auth) ---
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10

# --- CPR scanning / OCR ---
# OCR_PROVIDER = tesseract | google-vision
OCR_PROVIDER=tesseract
GOOGLE_VISION_API_KEY=

# --- S3-compatible file storage ---
S3_BUCKET=kca-its-uploads
S3_REGION=me-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
